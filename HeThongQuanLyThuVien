/*----- PHAN TICH NGAY ----*/	
static int parseDate(const char *s, struct tm *out) {
    memset(out, 0, sizeof(struct tm));
    if (!s || s[0] == '\0') return 0;
    if (sscanf(s, "%d/%d/%d", &out->tm_mday,&out->tm_mon,&out->tm_year) != 3) return 0;
    out->tm_mon  -= 1;       
    out->tm_year -= 1900;    
    out->tm_hour  = 12;      
    mktime(out);             
    return 1;
}
 
