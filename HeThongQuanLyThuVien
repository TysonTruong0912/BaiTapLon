void inThongBao(const char *msg, int loai) {
    printf("\n  ");
    if (loai == 1) {
        SET_COLOR(COLOR_GREEN);
        printf("[OK] ");
    } else if (loai == 0) {
        SET_COLOR(COLOR_RED);
        printf("[LOI] ");
    } else {
        SET_COLOR(COLOR_YELLOW);
        printf("[!] ");
    }
    SET_COLOR(COLOR_WHITE);
    printf("%s\n", msg);
}

