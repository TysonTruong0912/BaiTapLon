/* ===== CAU TRUC DU LIEU ===== */

typedef struct {
    int id;
    char tensach[100];
    int soLuong;
} Sach;

typedef struct {
    char idSach[50];
    char idSinhVien[50];
    char ngayMuon[50];
    char ngayTra[50];
} Borrow;

typedef struct {
    char idSV[50];
    char tenSV[100];
} Reader;

typedef struct NodeReader {
    Reader data;
    struct NodeReader *next;
} NodeReader;

typedef struct NodeBorrow {
    Borrow data;
    struct NodeBorrow *next;
} NodeBorrow;

typedef struct {
    NodeReader *head;
} ListReader;

typedef struct {
    NodeBorrow *head;
} ListBorrow;

